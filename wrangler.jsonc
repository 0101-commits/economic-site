{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ecom-dashboard-proxy",
  "main": "cloudflare-worker/worker.js",
  "compatibility_date": "2026-05-29",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  // Cloudflare Workers AI 바인딩 — AI 시황 요약을 '무료(키 불필요)' 로 Worker 안에서 직접 실행.
  // 무료 플랜 일 10,000 Neurons 제공(개인용 충분). 외부 API 키·비용 없이 env.AI.run() 으로 LLM 호출.
  "ai": {
    "binding": "AI"
  },
  // 📝 분석 노트 클라우드 동기화 (GET/POST /notes) — 비공개 KV 스토리지 (Task 2.1).
  // 활성화 방법:
  //   1. `npx wrangler kv namespace create NOTES_KV` 실행 → 출력된 id 를 아래에 기입
  //   2. 아래 블록의 주석을 해제하고 재배포 (`npx wrangler deploy`)
  //   3. (권장) `npx wrangler secret put NOTES_SYNC_KEY` 로 동기화 키 설정
  //      — 미설정 시 ALERTS_SYNC_KEY 를 재사용하며, 둘 다 없으면 키 검증 없이 동작
  // 바인딩이 없으면 /notes 는 503(no_kv_binding)을 반환하고 나머지 기능은 영향 없다.
  // "kv_namespaces": [
  //   { "binding": "NOTES_KV", "id": "<wrangler kv namespace create NOTES_KV 출력 id>" }
  // ],
  // ⏰ Cron Triggers — 카카오 시황 자동 발송 트리거(GitHub Actions 스케줄이 best-effort 라 누락되는
  // 문제 해소). 이 시각에 Worker 의 scheduled() 가 GitHub repository_dispatch 로 kakao-daily 워크플로를
  // on-demand 실행시킨다(차트 생성·발송은 GitHub Actions 가). on-demand 라 스케줄 드롭 영향이 없다.
  // 발송 슬롯(KST): 매일 07~17시 매시간 + 20·22시(13회) — 카카오 도착 목표는 각 시각 '03분'.
  // (2026-06 사용자 요청: 07~16시 매시간으로 확대, 저녁 17·20·22시는 유지)
  // 크론 발화→dispatch→잡 기동→발송까지 실측 약 60초가 걸려 :02(UTC)에 발화시킨다.
  // UTC 환산: 22·23·00~08시 = KST 07~17시(매시간) / 11:02 = 20시 / 13:02 = 22시.
  // Cloudflare 는 Worker 당 cron 5개 제한이라 한 식으로 합침.
  // 동작에는 Worker 시크릿 GH_DISPATCH_TOKEN(저장소 dispatch 권한 PAT) 이 필요하다(README 참고).
  // ⚠️ cron 변경은 Worker 재배포(main 머지 → 자동 배포 또는 `npx wrangler deploy`) 후에 적용된다.
  "triggers": {
    "crons": ["2 0-8,11,13,22,23 * * *"]
  }
}
